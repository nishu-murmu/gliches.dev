---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<Layout>
  <section class="py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-2 text-[#1d1e20] dark:text-[#FFFDF6]">
      Blogs
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      Thoughts on code, tools, and building things.
    </p>

    <div class="flex flex-wrap gap-2 mb-10" id="tag-filters">
      <button
        class="tag-btn px-3 py-1 text-xs rounded-full border font-medium transition-all duration-200 cursor-pointer bg-[#48e2d5] text-[#1d1e20] border-[#48e2d5] dark:bg-[#48e2d5] dark:text-[#1d1e20] dark:border-[#48e2d5]"
        data-tag="all"
      >
        all
      </button>
      {allTags.map((tag) => (
        <button
          class="tag-btn px-3 py-1 text-xs rounded-full border font-medium transition-all duration-200 cursor-pointer bg-transparent text-[#1d1e20] dark:text-[#48e2d5] border-[#48e2d5]/30 hover:bg-[#48e2d5]/20"
          data-tag={tag}
        >
          {tag}
        </button>
      ))}
    </div>

    <ul class="space-y-8" id="post-list">
      {posts.map((post) => (
        <li data-tags={post.data.tags.join(",")}>
          <a
            href={`/blogs/${post.id}`}
            class="block group"
          >
            <article class="p-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-[#282a2c]/50 hover:border-[#48e2d5]/50 transition-colors duration-300">
              <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
              <h2 class="text-xl font-semibold mb-2 text-[#1d1e20] dark:text-[#FFFDF6] group-hover:text-[#48e2d5] transition-colors duration-300">
                {post.data.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-300 mb-3">
                {post.data.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 text-xs rounded bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          </a>
        </li>
      ))}
    </ul>

    <div
      id="pagination"
      class="mt-10 flex flex-col gap-4 items-center"
    >
      <div class="flex items-center gap-2">
        <button
          id="pagination-prev"
          class="px-4 py-2 text-sm rounded-md border border-[#48e2d5]/30 text-[#1d1e20] dark:text-[#48e2d5] hover:bg-[#48e2d5]/10 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-200"
          type="button"
        >
          Previous
        </button>
        <div id="pagination-pages" class="flex flex-wrap justify-center gap-2"></div>
        <button
          id="pagination-next"
          class="px-4 py-2 text-sm rounded-md border border-[#48e2d5]/30 text-[#1d1e20] dark:text-[#48e2d5] hover:bg-[#48e2d5]/10 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-200"
          type="button"
        >
          Next
        </button>
      </div>
      <p id="pagination-status" class="text-sm text-gray-500 dark:text-gray-400"></p>
    </div>

    <div id="no-results" class="text-center py-16 hidden">
      <p class="text-gray-500 dark:text-gray-400 text-lg">No posts found for this category.</p>
    </div>

    {posts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-gray-500 dark:text-gray-400 text-lg">No posts yet. Check back soon!</p>
      </div>
    )}
  </section>
</Layout>

<script>
  const POSTS_PER_PAGE = 10;
  const tagButtons = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const postItems = Array.from(document.querySelectorAll<HTMLLIElement>("#post-list li"));
  const noResults = document.getElementById("no-results");
  const pagination = document.getElementById("pagination");
  const paginationPages = document.getElementById("pagination-pages");
  const paginationStatus = document.getElementById("pagination-status");
  const prevButton = document.getElementById("pagination-prev") as HTMLButtonElement | null;
  const nextButton = document.getElementById("pagination-next") as HTMLButtonElement | null;
  let activeTag = "all";
  let currentPage = 1;

  function getFilteredItems() {
    return postItems.filter((item) => {
      const tags = (item.dataset.tags ?? "").split(",");
      return activeTag === "all" || tags.includes(activeTag);
    });
  }

  function updateTagStyles() {
    tagButtons.forEach((btn) => {
      const isActive = btn.dataset.tag === activeTag;
      if (isActive) {
        btn.classList.add("bg-[#48e2d5]", "text-[#1d1e20]", "border-[#48e2d5]", "dark:bg-[#48e2d5]", "dark:text-[#1d1e20]", "dark:border-[#48e2d5]");
        btn.classList.remove("bg-transparent", "text-[#1d1e20]", "dark:text-[#48e2d5]", "border-[#48e2d5]/30");
      } else {
        btn.classList.remove("bg-[#48e2d5]", "text-[#1d1e20]", "border-[#48e2d5]", "dark:bg-[#48e2d5]", "dark:text-[#1d1e20]", "dark:border-[#48e2d5]");
        btn.classList.add("bg-transparent", "text-[#1d1e20]", "dark:text-[#48e2d5]", "border-[#48e2d5]/30");
      }
    });
  }

  function renderPagination(totalPages: number, visibleCount: number) {
    if (!paginationPages || !paginationStatus || !prevButton || !nextButton || !pagination) {
      return;
    }

    pagination.classList.toggle("hidden", visibleCount === 0 || totalPages <= 1);
    paginationPages.innerHTML = "";

    if (totalPages === 0) {
      prevButton.disabled = true;
      nextButton.disabled = true;
      paginationStatus.textContent = "";
      return;
    }

    for (let page = 1; page <= totalPages; page++) {
      const button = document.createElement("button");
      const isActive = page === currentPage;
      button.type = "button";
      button.textContent = String(page);
      button.className = `min-w-10 px-3 py-2 text-sm rounded-md border transition-colors duration-200 ${isActive
        ? "bg-[#48e2d5] text-[#1d1e20] border-[#48e2d5]"
        : "border-[#48e2d5]/30 text-[#1d1e20] dark:text-[#48e2d5] hover:bg-[#48e2d5]/10"}`;
      button.addEventListener("click", () => {
        currentPage = page;
        renderPosts();
      });
      paginationPages.appendChild(button);
    }

    prevButton.disabled = currentPage === 1;
    nextButton.disabled = currentPage === totalPages;
    paginationStatus.textContent = `${visibleCount} post${visibleCount === 1 ? "" : "s"} in ${activeTag === "all" ? "all categories" : activeTag}`;
  }

  function renderPosts() {
    const filteredItems = getFilteredItems();
    const totalPages = Math.ceil(filteredItems.length / POSTS_PER_PAGE);

    if (totalPages > 0 && currentPage > totalPages) {
      currentPage = totalPages;
    }

    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    postItems.forEach((item) => {
      item.style.display = "none";
    });

    filteredItems.slice(start, end).forEach((item) => {
      item.style.display = "";
    });

    if (noResults) {
      noResults.classList.toggle("hidden", filteredItems.length > 0);
    }

    updateTagStyles();
    renderPagination(totalPages, filteredItems.length);
  }

  function updateFilter(tag: string) {
    activeTag = tag;
    currentPage = 1;
    renderPosts();
  }

  tagButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      updateFilter(btn.dataset.tag ?? "all");
    });
  });

  prevButton?.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage -= 1;
      renderPosts();
    }
  });

  nextButton?.addEventListener("click", () => {
    const totalPages = Math.ceil(getFilteredItems().length / POSTS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage += 1;
      renderPosts();
    }
  });

  renderPosts();
</script>
