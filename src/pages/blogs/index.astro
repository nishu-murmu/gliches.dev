---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../config/site";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout>
  <section class="py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-2 text-[var(--color-heading)]">
      {siteConfig.blog.title}
    </h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      {siteConfig.blog.description}
    </p>

    <ul class="space-y-8" id="post-list">
      {posts.map((post) => (
        <li>
          <a
            href={`/blogs/${post.id}`}
            class="block group"
          >
            <article class="p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] transition-colors duration-300">
              <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
              <h2 class="text-xl font-semibold mb-2 text-[var(--color-heading)] group-hover:text-[var(--color-accent)] transition-colors duration-300">
                {post.data.title}
              </h2>
              <p class="text-gray-600 dark:text-gray-300 mb-3">
                {post.data.description}
              </p>
            </article>
          </a>
        </li>
      ))}
    </ul>

    <div
      id="pagination"
      class="mt-10 flex flex-col gap-4 items-center"
    >
      <div class="flex items-center gap-2">
        <button
          id="pagination-prev"
          class="px-4 py-2 text-sm rounded-md border border-[var(--color-tag-border)] text-[var(--color-tag-text)] hover:bg-[var(--color-accent-soft)] disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-200"
          type="button"
        >
          Previous
        </button>
        <div id="pagination-pages" class="flex flex-wrap justify-center gap-2"></div>
        <button
          id="pagination-next"
          class="px-4 py-2 text-sm rounded-md border border-[var(--color-tag-border)] text-[var(--color-tag-text)] hover:bg-[var(--color-accent-soft)] disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-200"
          type="button"
        >
          Next
        </button>
      </div>
      <p id="pagination-status" class="text-sm text-gray-500 dark:text-gray-400"></p>
    </div>

    {posts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-gray-500 dark:text-gray-400 text-lg">{siteConfig.blog.emptyState}</p>
      </div>
    )}
  </section>
</Layout>

<script define:vars={{ postsPerPage: siteConfig.blog.postsPerPage }}>
  const POSTS_PER_PAGE = postsPerPage;
  const postItems = Array.from(document.querySelectorAll("#post-list li"));
  const pagination = document.getElementById("pagination");
  const paginationPages = document.getElementById("pagination-pages");
  const paginationStatus = document.getElementById("pagination-status");
  const prevButton = document.getElementById("pagination-prev");
  const nextButton = document.getElementById("pagination-next");
  let currentPage = 1;

  function renderPagination(totalPages, visibleCount) {
    if (!paginationPages || !paginationStatus || !prevButton || !nextButton || !pagination) {
      return;
    }

    pagination.classList.toggle("hidden", visibleCount === 0 || totalPages <= 1);
    paginationPages.innerHTML = "";

    if (totalPages === 0) {
      prevButton.disabled = true;
      nextButton.disabled = true;
      paginationStatus.textContent = "";
      return;
    }

    for (let page = 1; page <= totalPages; page++) {
      const button = document.createElement("button");
      const isActive = page === currentPage;
      button.type = "button";
      button.textContent = String(page);
      button.className = `min-w-10 px-3 py-2 text-sm rounded-md border transition-colors duration-200 ${isActive
        ? "bg-[var(--color-accent)] text-[#fffdf6] dark:text-[#1d1e20] border-[var(--color-accent)]"
        : "border-[var(--color-tag-border)] text-[var(--color-tag-text)] hover:bg-[var(--color-accent-soft)]"}`;
      button.addEventListener("click", () => {
        currentPage = page;
        renderPosts();
      });
      paginationPages.appendChild(button);
    }

    prevButton.disabled = currentPage === 1;
    nextButton.disabled = currentPage === totalPages;
    paginationStatus.textContent = `${visibleCount} post${visibleCount === 1 ? "" : "s"} total`;
  }

  function renderPosts() {
    const totalPages = Math.ceil(postItems.length / POSTS_PER_PAGE);

    if (totalPages > 0 && currentPage > totalPages) {
      currentPage = totalPages;
    }

    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;

    postItems.forEach((item) => {
      item.style.display = "none";
    });

    postItems.slice(start, end).forEach((item) => {
      item.style.display = "";
    });

    renderPagination(totalPages, postItems.length);
  }

  prevButton?.addEventListener("click", () => {
    if (currentPage > 1) {
      currentPage -= 1;
      renderPosts();
    }
  });

  nextButton?.addEventListener("click", () => {
    const totalPages = Math.ceil(postItems.length / POSTS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage += 1;
      renderPosts();
    }
  });

  renderPosts();
</script>
