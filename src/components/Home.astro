---
import { Github, Instagram, Linkedin, ExternalLink, Star, GitFork } from "lucide-react";
---

<section id="hero" class="py-16 text-center">
  <div class="hero-content max-w-3xl mx-auto">
    <div class="flex items-center justify-center mb-6">
      <div class="glitch-wrapper">
        <img
          src="/github-me.jpeg"
          alt="Nishu Murmu"
          class="glitch-img h-40 w-40 rounded-full"
        />
        <img
          src="/real-me.jpg"
          alt="Nishu Murmu"
          class="glitch-img h-40 w-40 rounded-full"
        />
      </div>
    </div>
    <h2
      class="text-2xl md:text-2xl font-bold mt-6 text-[#1d1e20] dark:text-[#FFFDF6]"
    >
      Nishu Murmu
    </h2>
    <h4 class="mb-4 font-medium">
      Software Developer | Calisthenics Enthusiast | Cinephile
    </h4>
    <p class="text-md md:text-md mb-8 text-gray-600 dark:text-gray-300">
      23yr old guy, software developer specializing in browser extensions. Very
      passionate about linux, neovim, Calisthenics, chess, movies, shows, pop
      culture, philosophy, etc.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://github.com/nishu-murmu"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Github class="h-8 w-8" />
      </a>
      <a
        href="https://www.instagram.com/_nishu_murmu_/"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Instagram class="h-8 w-8" />
      </a>
      <a
        href="https://www.linkedin.com/in/nishu-murmu/"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Linkedin class="h-8 w-8" />
      </a>
    </div>
  </div>
</section>

<section id="projects" class="py-16 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-[#1d1e20] dark:text-[#FFFDF6]">
      Projects
    </h2>
    <ul class="space-y-6 list-disc pl-6">
      <li>
        <a
          href="https://bastionresearch.in/"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          Bastion Research
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          Stocks and Brokerage suggestion and research application, which was migrated from wordpress to react from scratch.
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">Typescript</span>
      </li>
      <li>
        <a
          href="https://www.trilokwall.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          Trilok Wall
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          Designed and developed the marketing website for Trilok Wall. Trilok Precast offers a wide range of RCC precast construction solutions used in residential, industrial, and commercial sites across India.
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">Typescript</span>
      </li>
      <li>
        <a
          href="https://github.com/nishu-murmu/ThemeSwitch.nvim"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          ThemeSwitch.nvim
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          🎨 Light weight colorscheme switcher for neovim.
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">Lua</span>
        <span class="inline-flex items-center gap-1 text-gray-500 dark:text-gray-400 text-sm align-middle ml-2">
          <Star className="h-4 w-4" />
          <span>4</span>
        </span>
      </li>
      <li>
        <a
          href="https://github.com/nishu-murmu/cursor-inline"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          cursor-inline
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          Cursor style Inline editing plugin for neovim.
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">Lua</span>
        <span class="inline-flex items-center gap-1 text-gray-500 dark:text-gray-400 text-sm align-middle ml-2">
          <Star className="h-4 w-4" />
          <span>5</span>
        </span>
        <span class="inline-flex items-center gap-1 text-gray-500 dark:text-gray-400 text-sm align-middle ml-2">
          <GitFork className="h-4 w-4" />
          <span>1</span>
        </span>
      </li>
      <li>
        <a
          href="https://github.com/nishu-murmu/Youtube-Video-Scheduler"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          Youtube-Video-Scheduler
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          ⏰ A browser extension to schedule videos on youtube, incase you want to watch something later
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">TypeScript</span>
        <span class="inline-flex items-center gap-1 text-gray-500 dark:text-gray-400 text-sm align-middle ml-2">
          <Star className="h-4 w-4" />
          <span>2</span>
        </span>
      </li>
      <li>
        <a
          href="https://github.com/nishu-murmu/WhatsApp-Toggle"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-blue-700 dark:text-blue-400 hover:underline"
        >
          WhatsApp-Toggle
        </a>
        <span class="block text-gray-600 dark:text-gray-300 ml-0">
          Small chrome extension to toggle whatsApp left sidebar chats.
        </span>
        <span class="inline-block my-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 text-xs align-middle">JavaScript</span>
      </li>
    </ul>
  </div>
</section>
