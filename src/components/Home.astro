---
import { Github, Instagram, Linkedin, ExternalLink, Star, GitFork } from "lucide-react";
---

<section id="hero" class="py-16 text-center">
  <div class="hero-content max-w-3xl mx-auto">
    <div class="flex items-center justify-center mb-6">
      <div class="glitch-wrapper">
        <img
          src="/github-me.jpeg"
          alt="Nishu Murmu"
          class="glitch-img h-40 w-40 rounded-full"
        />
        <img
          src="/real-me.jpg"
          alt="Nishu Murmu"
          class="glitch-img h-40 w-40 rounded-full"
        />
      </div>
    </div>
    <h2
      class="text-2xl md:text-2xl font-bold mt-6 text-[#1d1e20] dark:text-[#FFFDF6]"
    >
      Nishu Murmu
    </h2>
    <h4 class="mb-4 font-medium">
      Software Developer | Calisthenics Enthusiast | Cinephile
    </h4>
    <p class="text-md md:text-md mb-8 text-gray-600 dark:text-gray-300">
      23yr old guy, software developer specializing in browser extensions. Very
      passionate about linux, neovim, Calisthenics, chess, movies, shows, pop
      culture, philosophy, etc.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="https://github.com/nishu-murmu"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Github class="h-8 w-8" />
      </a>
      <a
        href="https://www.instagram.com/_nishu_murmu_/"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Instagram class="h-8 w-8" />
      </a>
      <a
        href="https://www.linkedin.com/in/nishu-murmu/"
        class="cursor-pointer px-2.5 py-2 rounded-full dark:bg-[#282a2c] bg-[#ffffff]"
      >
        <Linkedin class="h-8 w-8" />
      </a>
    </div>
  </div>
</section>

<section id="projects" class="py-16 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-[#1d1e20] dark:text-[#FFFDF6]">
      Projects
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- ThemeSwitch.nvim -->
      <div class="p-6 rounded-lg shadow-lg bg-gray-800/50 dark:bg-gray-800/50 bg-white/50 backdrop-blur-sm border border-gray-700 dark:border-gray-700 border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold text-[#1d1e20] dark:text-[#FFFDF6]">
            ThemeSwitch.nvim
          </h3>
          <a
            href="https://github.com/nishu-murmu/ThemeSwitch.nvim"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            <ExternalLink class="h-5 w-5" />
          </a>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-4">
          🎨 Light weight colorscheme switcher for neovim.
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span class="px-2 py-1 rounded bg-gray-700 dark:bg-gray-700 bg-gray-100 text-gray-800 dark:text-gray-200">Lua</span>
          <div class="flex items-center gap-1">
            <Star class="h-4 w-4" />
            <span>4</span>
          </div>
        </div>
      </div>

      <!-- cursor-inline -->
      <div class="p-6 rounded-lg shadow-lg bg-gray-800/50 dark:bg-gray-800/50 bg-white/50 backdrop-blur-sm border border-gray-700 dark:border-gray-700 border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold text-[#1d1e20] dark:text-[#FFFDF6]">
            cursor-inline
          </h3>
          <a
            href="https://github.com/nishu-murmu/cursor-inline"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            <ExternalLink class="h-5 w-5" />
          </a>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-4">
          Cursor style Inline editing plugin for neovim.
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span class="px-2 py-1 rounded bg-gray-700 dark:bg-gray-700 bg-gray-100 text-gray-800 dark:text-gray-200">Lua</span>
          <div class="flex items-center gap-1">
            <Star class="h-4 w-4" />
            <span>5</span>
          </div>
          <div class="flex items-center gap-1">
            <GitFork class="h-4 w-4" />
            <span>1</span>
          </div>
        </div>
      </div>

      <!-- Youtube-Video-Scheduler -->
      <div class="p-6 rounded-lg shadow-lg bg-gray-800/50 dark:bg-gray-800/50 bg-white/50 backdrop-blur-sm border border-gray-700 dark:border-gray-700 border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold text-[#1d1e20] dark:text-[#FFFDF6]">
            Youtube-Video-Scheduler
          </h3>
          <a
            href="https://github.com/nishu-murmu/Youtube-Video-Scheduler"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            <ExternalLink class="h-5 w-5" />
          </a>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-4">
          ⏰ A browser extension to schedule videos on youtube, incase you want to watch something later
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span class="px-2 py-1 rounded bg-gray-700 dark:bg-gray-700 bg-gray-100 text-gray-800 dark:text-gray-200">TypeScript</span>
          <div class="flex items-center gap-1">
            <Star class="h-4 w-4" />
            <span>2</span>
          </div>
        </div>
      </div>

      <!-- WhatsApp-Toggle -->
      <div class="p-6 rounded-lg shadow-lg bg-gray-800/50 dark:bg-gray-800/50 bg-white/50 backdrop-blur-sm border border-gray-700 dark:border-gray-700 border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold text-[#1d1e20] dark:text-[#FFFDF6]">
            WhatsApp-Toggle
          </h3>
          <a
            href="https://github.com/nishu-murmu/WhatsApp-Toggle"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            <ExternalLink class="h-5 w-5" />
          </a>
        </div>
        <p class="text-gray-600 dark:text-gray-300 mb-4">
          Small chrome extension to toggle whatsApp left sidebar chats.
        </p>
        <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
          <span class="px-2 py-1 rounded bg-gray-700 dark:bg-gray-700 bg-gray-100 text-gray-800 dark:text-gray-200">JavaScript</span>
        </div>
      </div>
    </div>
  </div>
</section>
