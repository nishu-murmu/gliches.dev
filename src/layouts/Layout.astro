---
import "../styles/global.css";
import Header from "./MainLayout/Header";
import Footer from "./MainLayout/Footer";
import RootLayout from "./MainLayout/RootLayout";
import { siteConfig } from "../config/site";

const assetBase = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      (function () {
        var t = localStorage.getItem("toggleDarkMode");
        document.documentElement.classList.toggle("dark", t !== "light");
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${assetBase}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteConfig.seo.title}</title>
  </head>
  <RootLayout client:load>
    <div id="container" class="min-h-screen flex flex-col">
      <Header client:load />
      <main class="flex-1 max-w-3xl mx-auto px-8 w-full">
        <slot />
      </main>
      <Footer client:load />
    </div>
  </RootLayout>
</html>
